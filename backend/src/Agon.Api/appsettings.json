{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=agon;Username=agon_user;Password=agon_dev_password;Include Error Detail=true",
    "Redis": "localhost:6379",
    "BlobStorage": "${BLOB_STORAGE_CONNECTION_STRING}"
  },

  "Database": {
    "PostgreSql": {
      "UseManagedIdentity": false,
      "Host": "",
      "Port": 5432,
      "Database": "agon",
      "Username": ""
    }
  },

  "Redis": {
    "UseManagedIdentity": false,
    "Host": "",
    "Port": 6380
  },

  "Storage": {
    "UseManagedIdentity": false,
    "AttachmentBlobServiceUri": "",
    "AttachmentContainer": "session-attachments"
  },

  "AttachmentOperations": {
    "Retention": {
      "CleanupEnabled": true,
      "RetentionDays": 90,
      "CleanupIntervalMinutes": 60,
      "CleanupBatchSize": 100
    }
  },

  "ApiRateLimiting": {
    "Enabled": true,
    "SessionCreate": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "SessionMessage": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "AttachmentUpload": {
      "PermitLimit": 12,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },

  "TrialAccess": {
    "Enabled": false,
    "DefaultTrialDays": 7,
    "AdminApiKey": "",
    "AccessMode": "RestrictedGroups",
    "EnforceEntraGroupMembership": true,
    "RequiredEntraGroupObjectIds": [],
    "RequiredEntraGroupObjectIdsCsv": "",
    "AdminBypassEntraGroupObjectIds": [],
    "AdminBypassEntraGroupObjectIdsCsv": "",
    "Quota": {
      "Enabled": true,
      "TokenLimit": 40000,
      "WindowDays": 7
    },
    "RequestRateLimit": {
      "Enabled": true,
      "RequestsPerMinute": 20,
      "BurstCapacity": 10
    }
  },

  "AttachmentProcessing": {
    "MaxExtractedTextChars": 200000,
    "DocumentIntelligence": {
      "Enabled": true,
      "Endpoint": "",
      "ModelId": "prebuilt-layout",
      "ApiVersion": "2024-11-30",
      "UseManagedIdentity": true,
      "ApiKey": "",
      "PollIntervalMs": 1500,
      "MaxPollAttempts": 40
    },
    "OpenAiVision": {
      "Enabled": true,
      "Model": "gpt-4o-mini",
      "FallbackModel": "",
      "MaxTokens": 1200,
      "Detail": "auto",
      "MaxImageBytes": 20971520
    },
    "ChunkLoop": {
      "Enabled": true,
      "ActivationThresholdChars": 14000,
      "ChunkSizeChars": 12000,
      "ChunkOverlapChars": 1000,
      "MaxChunksPerAttachment": 20,
      "MaxChunkNoteChars": 1200,
      "MaxFinalNotesPerAgent": 8
    }
  },

  "LLM": {
    "OpenAI": {
      "ApiKey": "${OPENAI_KEY}",
      "Model": "gpt-5.2",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "Anthropic": {
      "ApiKey": "${CLAUDE_KEY}",
      "Model": "claude-opus-4-6",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "Google": {
      "ApiKey": "${GEMINI_KEY}",
      "Model": "gemini-3-flash-preview",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "DeepSeek": {
      "ApiKey": "${DEEPSEEK_KEY}",
      "Model": "deepseek-v3.2",
      "MaxTokens": 4000,
      "Temperature": 0.7
    }
  },

  "Agon": {
    "DefaultFrictionLevel": 50,
    "MaxClarificationRounds": 2,
    "MaxDebateRounds": 2,
    "MaxTargetedLoops": 2,
    "SessionBudgetTokens": 50000,
    "ConvergenceThreshold": 0.75,
    "HighFrictionThreshold": 70,
    "MinCliVersion": "0.1.3"
  },

  "Authentication": {
    "Enabled": false,
    "AzureAd": {
      "TenantId": "",
      "ClientId": "",
      "InteractiveClientId": "",
      "Audience": "",
      "Authority": ""
    }
  },

  "Cors": {
    "AllowedOrigins": []
  }
}
