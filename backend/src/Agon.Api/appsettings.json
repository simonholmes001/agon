{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=agon;Username=agon_user;Password=agon_dev_password;Include Error Detail=true",
    "Redis": "localhost:6379",
    "BlobStorage": "${BLOB_STORAGE_CONNECTION_STRING}"
  },

  "Storage": {
    "AttachmentContainer": "session-attachments"
  },

  "AttachmentProcessing": {
    "MaxExtractedTextChars": 12000,
    "DocumentIntelligence": {
      "Enabled": true,
      "Endpoint": "",
      "ModelId": "prebuilt-layout",
      "ApiVersion": "2024-11-30",
      "UseManagedIdentity": true,
      "ApiKey": "",
      "PollIntervalMs": 1500,
      "MaxPollAttempts": 40
    },
    "OpenAiVision": {
      "Enabled": true,
      "Model": "gpt-4o-mini",
      "MaxTokens": 1200,
      "Detail": "auto",
      "MaxImageBytes": 6291456
    }
  },

  "LLM": {
    "OpenAI": {
      "ApiKey": "${OPENAI_KEY}",
      "Model": "gpt-5.2",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "Anthropic": {
      "ApiKey": "${CLAUDE_KEY}",
      "Model": "claude-opus-4-6",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "Google": {
      "ApiKey": "${GEMINI_KEY}",
      "Model": "gemini-3-flash-preview",
      "MaxTokens": 4000,
      "Temperature": 0.7
    },
    "DeepSeek": {
      "ApiKey": "${DEEPSEEK_KEY}",
      "Model": "deepseek-v3.2",
      "MaxTokens": 4000,
      "Temperature": 0.7
    }
  },

  "Agon": {
    "DefaultFrictionLevel": 50,
    "MaxClarificationRounds": 2,
    "MaxDebateRounds": 2,
    "MaxTargetedLoops": 2,
    "SessionBudgetTokens": 50000,
    "ConvergenceThreshold": 0.75,
    "HighFrictionThreshold": 70,
    "MinCliVersion": "0.1.3"
  },

  "Authentication": {
    "Enabled": false,
    "AzureAd": {
      "TenantId": "",
      "ClientId": "",
      "Audience": "",
      "Authority": ""
    }
  },

  "Cors": {
    "AllowedOrigins": []
  }
}
