# ============================================================================
# Agon Project .gitignore
# Covers both .NET backend and Next.js frontend
# ============================================================================

# ── Environment Variables ───────────────────────────────────────────────
.env
.env*.local
.env.development
.env.production

# ── .NET Backend ────────────────────────────────────────────────────────
# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.DS_Store

# Rider
.idea/
*.sln.iml

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
TestResults/
coverage/

# ── Next.js Frontend ────────────────────────────────────────────────────
# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/
build/
dist/

# production
/build

# testing
/coverage

# misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Common ──────────────────────────────────────────────────────────────
# OS
.DS_Store
Thumbs.db

# Keep CLI launcher tracked (prevents runtime drift in global symlink installs)
!cli/bin/
!cli/bin/run.js

# Sensitive files
*.pem
*.key
*.pfx

# IDE
*.swp
*.swo
*~

# ── Bicep Build Outputs ────────────────────────────────────────────────
# Generated by `az bicep build`; keep source .bicep/.parameters.json only.
infrastructure/bicep/main.json
infrastructure/bicep/modules/network-dev.json
infrastructure/bicep/modules/data-dev.json
infrastructure/bicep/modules/app-edge-dev.json
infrastructure/bicep/modules/keyvault-access-dev.json
